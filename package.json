    "subscribe-element",
    "zero-build",
    "dom-binding",
    "state-management",
    "path-based"
  ],
  "author": {
    "name": "Ajdin Imsirovic",
    "url": "https://www.linkedin.com/in/ajdin-imsirovic"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ImsirovicAjdin/everystate-renderer"
  },
  "homepage": "https://github.com/ImsirovicAjdin/everystate-renderer",
  "peerDependencies": {
    "@everystate/core": ">=1.0.5"
  },
  "scripts": {
    "test": "node self-test.js",
    "self-test": "node self-test.js",
    "test:integration": "node tests/renderer.test.js",
    "test:i": "node tests/renderer.test.js"
  },
  "devDependencies": {
    "@everystate/test": "^1.0.0"
  },
  "files": [
    "*.js",
